{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fredrikc3-sketch/VibeConfigStarterKit/schemas/process-catalogue.schema.json",
  "title": "Business Process Catalogue — hierarchical tree",
  "type": "object",
  "required": ["nodes"],
  "properties": {
    "_metadata": {
      "type": "object",
      "properties": {
        "schema_version": { "const": "1.0" },
        "source":         { "type": "string" },
        "totalNodes":     { "type": "integer", "minimum": 0 },
        "generatedAt":    { "type": "string", "format": "date-time" }
      }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id":       { "type": "string" },
        "parentId": { "type": ["string", "null"] },
        "name":     { "type": "string" },
        "level":    { "type": "integer", "minimum": 0 },
        "apqcCode": { "type": "string" },
        "module":   { "type": "string" },
        "children": { "type": "array", "items": { "$ref": "#/$defs/node" } }
      }
    }
  }
}
